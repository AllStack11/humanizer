OPENROUTER_API_KEY=sk-or-your-key-here
# Optional explicit secret file path (absolute or relative), for example:
# OPENROUTER_API_KEY_FILE=.voice-humanizer/openrouter_api_key
OPENROUTER_APP_URL=http://localhost:5173
OPENROUTER_APP_NAME=Voice Humanizer
# Optional comma-separated OpenRouter categories, e.g. productivity,writing
OPENROUTER_CATEGORIES=
# Optional override for local providers (no key needed on localhost), e.g. Ollama:
# OPENROUTER_API_URL=http://localhost:11434/v1/chat/completions
