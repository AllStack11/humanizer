{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Voice Humanizer",
  "version": "1.0.0",
  "identifier": "com.voicehumanizer.app",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:web"
  },
  "app": {
    "windows": [
      {
        "title": "Voice Humanizer",
        "width": 1120,
        "height": 760,
        "minWidth": 1180,
        "minHeight": 820,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
